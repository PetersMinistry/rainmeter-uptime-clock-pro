; Uptime Clock Pro shared styles

[StylePanelText]
FontFace=#FontText#
FontColor=#TextColor#
AntiAlias=1
StringEffect=Shadow
FontEffectColor=#Shadow#

[StyleLabel]
MeterStyle=StylePanelText
FontSize=9
FontWeight=600
FontColor=#MutedText#
StringCase=Upper

[StyleValue]
MeterStyle=StylePanelText
FontSize=20
FontWeight=600

[StyleSmall]
MeterStyle=StylePanelText
FontSize=10
FontColor=#SoftText#

[StyleTiny]
MeterStyle=StylePanelText
FontSize=8
FontColor=#MutedText#
